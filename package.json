{
  "name": "runtrail",
  "version": "1.29.1",
  "description": "Self-hosted agent activity ledger",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "tsx src/smoke.ts",
    "lint": "biome check . && knip",
    "format": "biome check --write .",
    "release": "semantic-release",
    "cli": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/index.ts",
    "mcp:bridge": "tsx src/mcp/bridge.ts"
  },
  "bin": {
    "rt": "dist/cli/index.js",
    "runtrail-codex-hook": "dist/integrations/codexHook.js",
    "runtrail-mcp": "dist/mcp/index.js",
    "runtrail-mcp-bridge": "dist/mcp/bridge.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.5.0",
    "commander": "^15.0.0",
    "hono": "^4.12.28",
    "nanoid": "^5.1.16",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "knip": "^6.25.0",
    "semantic-release": "^25.0.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
