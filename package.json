{
  "name": "runtrail",
  "version": "0.1.0",
  "description": "Self-hosted agent activity ledger",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cli": "tsx src/cli/index.ts"
  },
  "bin": {
    "rt": "dist/cli/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "better-sqlite3": "^12.5.0",
    "commander": "^14.0.2",
    "hono": "^4.10.7",
    "nanoid": "^5.1.6",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
